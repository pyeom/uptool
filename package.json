{
  "name": "uptool",
  "version": "0.1.0",
  "description": "Serve LLM-generated HTML files via wildcard subdomains on your own domain",
  "type": "commonjs",
  "bin": {
    "uptool": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "html",
    "serve",
    "llm",
    "subdomain",
    "cli"
  ],
  "license": "MIT",
  "allowScripts": {
    "esbuild@0.27.7": true
  }
}
